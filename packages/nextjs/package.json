{
  "name": "@captigo/nextjs",
  "version": "0.1.0",
  "description": "Next.js helpers for captigo — token extraction, IP forwarding, and route handler verification",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@captigo/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "captigo",
    "captcha",
    "nextjs",
    "next",
    "app-router",
    "turnstile",
    "hcaptcha",
    "security",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/moritzmyrz/captigo/tree/main/packages/nextjs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzmyrz/captigo.git",
    "directory": "packages/nextjs"
  },
  "bugs": {
    "url": "https://github.com/moritzmyrz/captigo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
