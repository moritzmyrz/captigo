{
  "name": "@captigo/core",
  "version": "0.1.0",
  "description": "Provider-agnostic CAPTCHA integration for the modern web",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "captigo",
    "captcha",
    "hcaptcha",
    "recaptcha",
    "turnstile",
    "cloudflare",
    "security",
    "typescript",
    "provider-agnostic"
  ],
  "license": "MIT",
  "homepage": "https://github.com/moritzmyrz/captigo/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzmyrz/captigo.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/moritzmyrz/captigo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
