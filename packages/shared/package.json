{
  "name": "@captigo/shared",
  "version": "0.0.0",
  "description": "Internal shared utilities for the captigo monorepo — not for public consumption",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.3"
  }
}
