{
  "name": "@captigo/react",
  "version": "0.1.0",
  "description": "React hooks and components for captigo",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@captigo/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^3.1.1",
    "jsdom": "^26.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "captcha",
    "react",
    "hooks",
    "components",
    "security",
    "typescript",
    "captigo"
  ],
  "license": "MIT",
  "homepage": "https://github.com/moritzmyrz/captigo/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzmyrz/captigo.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/moritzmyrz/captigo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
