{
  "name": "@captigo/react",
  "version": "0.0.0",
  "description": "React hooks and components for captigo",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "captigo": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.3"
  },
  "keywords": ["captcha", "react", "hooks", "components"],
  "license": "MIT",
  "homepage": "https://github.com/moritzmyrz/captigo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzmyrz/captigo.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/moritzmyrz/captigo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
