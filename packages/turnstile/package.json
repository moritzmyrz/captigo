{
  "name": "@captigo/turnstile",
  "version": "0.1.0",
  "description": "Cloudflare Turnstile adapter for Captigo — client widget and server-side verification",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@captigo/core": "workspace:*"
  },
  "devDependencies": {
    "@captigo/shared": "workspace:*",
    "@vitest/coverage-v8": "^3.1.1",
    "jsdom": "^26.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "bot-management",
    "captigo",
    "captcha",
    "cloudflare",
    "security",
    "turnstile",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/moritzmyrz/captigo/tree/main/packages/turnstile#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/moritzmyrz/captigo.git",
    "directory": "packages/turnstile"
  },
  "bugs": {
    "url": "https://github.com/moritzmyrz/captigo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
